{
  "name": "@pinooxhq/pinion-client",
  "version": "1.2.0",
  "description": "Client for Pinion — resumable uploads with fetch or Axios, retry, resume, progress ETA, and unwrap presets",
  "type": "module",
  "license": "MIT",
  "author": "Pinoox <dev@pinoox.com>",
  "homepage": "https://github.com/pinoox/pinion/tree/master/client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinoox/pinion.git",
    "directory": "client"
  },
  "bugs": {
    "url": "https://github.com/pinoox/pinion/issues"
  },
  "keywords": [
    "pinoox",
    "pinion",
    "upload",
    "axios",
    "fetch",
    "resumable",
    "chunked-upload",
    "multipart",
    "browser",
    "vue",
    "react",
    "fluent-api",
    "typescript"
  ],
  "files": [
    "src",
    "types",
    "pinion-axios.js",
    "README.md",
    "LICENSE"
  ],
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./legacy": {
      "import": "./pinion-axios.js",
      "default": "./pinion-axios.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "axios": ">=1.6.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    }
  }
}
