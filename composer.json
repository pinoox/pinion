{
  "name": "pinoox/pinion",
  "version": "1.0.0",
  "description": "Pinion — resumable chunked upload protocol for PHP (Pinoox, Laravel, any framework)",
  "type": "library",
  "license": "MIT",
  "keywords": ["pinoox", "pinion", "upload", "chunk", "resumable", "laravel", "axios"],
  "authors": [
    {
      "name": "Pinoox",
      "email": "dev@pinoox.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "symfony/http-foundation": "^6.4|^7.0"
  },
  "require-dev": {
    "pestphp/pest": "^1.23",
    "illuminate/support": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Pinoox\\Pinion\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Pinoox\\Pinion\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pinoox\\Pinion\\Laravel\\PinionServiceProvider"
      ],
      "aliases": {
        "Pinion": "Pinoox\\Pinion\\Laravel\\Facades\\Pinion"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
